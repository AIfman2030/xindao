/* pages/chat/chat.wxss */

.chat-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #FFFFFF;
}

/* 顶部导航 */
.chat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  background: #FFFFFF;
  border-bottom: 1px solid #F5EDE6;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 10px;
}

.advisor-avatar {
  width: 42px;
  height: 42px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
}

.advisor-info {
  display: flex;
  flex-direction: column;
}

.advisor-name {
  font-size: 16px;
  font-weight: 600;
  color: #5D4E45;
}

.advisor-desc {
  font-size: 12px;
  color: #8B7B6B;
}

.header-right {
  font-size: 20px;
}

.icon-more {
  cursor: pointer;
}

/* 消息区域 */
.chat-messages {
  flex: 1;
  padding: 16px;
  overflow-y: auto;
  background: #FFF8F3;
}

/* 欢迎横幅 */
.welcome-banner {
  background: linear-gradient(135deg, #FF9A76 0%, #FF7E5F 100%);
  border-radius: 20px;
  padding: 18px;
  margin-bottom: 20px;
  color: #FFFFFF;
}

.welcome-header {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 10px;
}

.welcome-avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
}

.welcome-title {
  font-weight: 600;
  font-size: 14px;
}

.welcome-text {
  font-size: 14px;
  line-height: 1.7;
  opacity: 0.95;
}

/* 消息气泡 */
.message {
  display: flex;
  margin-bottom: 16px;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.message-user {
  justify-content: flex-end;
}

.message-ai {
  justify-content: flex-start;
}

.message-avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  flex-shrink: 0;
}

.message-bubble {
  max-width: 78%;
  padding: 12px 16px;
  border-radius: 16px;
  font-size: 15px;
  line-height: 1.6;
}

.user-bubble {
  background: linear-gradient(135deg, #FF9A76 0%, #FF7E5F 100%);
  color: #FFFFFF;
  border-bottom-right-radius: 4px;
}

.ai-bubble {
  background: #FFFFFF;
  color: #5D4E45;
  border-bottom-left-radius: 4px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
}

.message-sender {
  display: block;
  font-size: 11px;
  color: #8B7B6B;
  margin-bottom: 4px;
}

.message-content {
  display: block;
}

.message-content text {
  color: inherit;
}

/* 行动卡 */
.action-card-container {
  margin-bottom: 16px;
}

.action-card {
  background: #FFFFFF;
  border-radius: 16px;
  padding: 16px;
  border: 1px solid #F5EDE6;
}

.action-card-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 14px;
}

.action-icon {
  font-size: 18px;
}

.action-title {
  font-size: 14px;
  font-weight: 600;
  color: #5D4E45;
  flex: 1;
}

.action-badge {
  background: #FFF5EE;
  color: #FF7E5F;
  padding: 4px 10px;
  border-radius: 10px;
  font-size: 11px;
  font-weight: 500;
}

.action-list {
  display: flex;
  flex-direction: column;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 0;
  border-bottom: 1px solid #F5EDE6;
}

.action-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.action-check {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  border: 2px solid #FF9A76;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s;
}

.action-check.done {
  background: #FF9A76;
  border-color: #FF7E5F;
}

.action-check text {
  color: #FFFFFF;
  font-size: 12px;
  font-weight: bold;
}

.action-content {
  flex: 1;
}

.action-text {
  display: block;
  font-size: 14px;
  color: #5D4E45;
  margin-bottom: 2px;
}

.action-item.completed .action-text {
  text-decoration: line-through;
  color: #B8A899;
}

.action-time {
  font-size: 12px;
  color: #B8A899;
}

/* 打字指示器 */
.typing-indicator {
  display: flex;
  gap: 4px;
  padding: 12px 16px;
  margin-bottom: 16px;
}

.typing-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #B8A899;
  animation: typing 1.4s infinite;
}

.typing-dot:nth-child(2) {
  animation-delay: 0.2s;
}

.typing-dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes typing {
  0%, 60%, 100% {
    transform: translateY(0);
    opacity: 0.4;
  }
  30% {
    transform: translateY(-6px);
    opacity: 1;
  }
}

/* 底部输入栏 */
.chat-input-bar {
  padding: 12px 16px 34px;
  background: #FFFFFF;
  border-top: 1px solid #F5EDE6;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 12px;
}

.input-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: #F8F4F0;
  border-radius: 24px;
  padding: 12px 16px;
}

.input-box input {
  flex: 1;
  border: none;
  background: transparent;
  font-size: 15px;
  color: #5D4E45;
  outline: none;
}

.input-box input::placeholder {
  color: #B8A899;
}

.voice-btn {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF9A76 0%, #FF7E5F 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  box-shadow: 0 4px 16px rgba(255, 126, 95, 0.3);
}

.voice-btn::after {
  border: none;
}

.voice-btn:active {
  transform: scale(0.95);
}

.voice-btn.recording {
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0%, 100% {
    box-shadow: 0 4px 16px rgba(255, 126, 95, 0.3);
  }
  50% {
    box-shadow: 0 4px 30px rgba(255, 126, 95, 0.6);
  }
}