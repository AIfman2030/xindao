# Environment Variables for 心岛 App

# OpenAI API Key (optional - uses mock responses if not set)
OPENAI_API_KEY=sk-your-api-key-here

# Email Configuration (optional - reminders won't work without this)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="心岛" <noreply@xindao.app>

# App URL (for email links)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Cron Secret (for protecting cron endpoints)
CRON_SECRET=your-secret-key